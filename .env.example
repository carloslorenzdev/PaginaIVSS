APP_NAME=Tiuna
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=es
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=es_VE

APP_MAINTENANCE_DRIVER=cache
APP_MAINTENANCE_STORE=redis

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=daily
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
LOG_DAILY_DAYS=180
LOG_ACCIONES_LEVEL=info
LOG_ACCIONES_DAILY_DAYS=365

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_SERVICE_NAME=laravel
# DB_USERNAME=root
# DB_PASSWORD=

# PARA CONSULTAS
DB_CONS_CONNECTION=sqlite
# DB_CONS_HOST=127.0.0.1
# DB_CONS_PORT=3306
# DB_CONS_DATABASE=laravel
# DB_CONS_SERVICE_NAME=laravel
# DB_CONS_USERNAME=root
# DB_CONS_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=10
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SAME_SITE=strict

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
DB_QUEUE_RETRY_AFTER=300
CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

CSP_ENABLED=true
CSP_NONCE_ENABLED=true
CSP_ENABLED_WHILE_HOT_RELOADING=false

SISTEMA_USUARIOS_DIAS_INACTIVIDAD=0

# password_confirm 5 minutos
AUTH_PASSWORD_TIMEOUT=300

OTP_GOOGLE2FA_ENABLED=true
OTP_GOOGLE2FA_LIFETIME=5

OTP_TELEGRAM2FA_ENABLED=true
OTP_TELEGRAM2FA_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
OTP_TELEGRAM2FA_LIFETIME=5
